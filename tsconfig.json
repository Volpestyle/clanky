{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"erasableSyntaxOnly": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": [
		"agent/**/*.ts",
		"bin/**/*.ts",
		"test/**/*.ts",
		"scripts/**/*.ts",
		"packages/**/*.ts",
		"packages/**/*.mts"
	]
}
