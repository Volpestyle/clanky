{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "src/**/*.test.ts",
    "dashboard/src/**/*.test.ts",
    "dashboard/src/**/*.test.tsx"
  ],
  "project": [
    "src/**/*.ts",
    "dashboard/src/**/*.ts",
    "dashboard/src/**/*.tsx",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "ignoreDependencies": [
    "@mermaid-js/mermaid-cli"
  ],
  "ignoreBinaries": [
    "agent-browser",
    "lsof",
    "rg"
  ]
}
