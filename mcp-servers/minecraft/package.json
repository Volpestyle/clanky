{
  "name": "clanky-minecraft-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server (stdio + HTTP) that lets Clanky control a Mineflayer bot with high-level Minecraft actions.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http-server.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "mineflayer": "^4.37.0",
    "mineflayer-collectblock": "^1.6.0",
    "mineflayer-pathfinder": "^2.4.5",
    "mineflayer-pvp": "^1.3.2",
    "mineflayer-tool": "^1.2.0",
    "node-canvas-webgl": "^0.3.0",
    "prismarine-viewer": "^1.33.0",
    "vec3": "^0.1.10"
  },
  "devDependencies": {
    "@types/node": "^22.15.31",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
