# Clanky .env.local template.
#
# Copy to .env.local (gitignored) and fill in what you use. Values here are
# read by every Clanky surface; the process environment wins over this file
# (agent/lib/env-store.ts). The full variable reference — 150+ vars, grouped by
# subsystem — is docs/env-reference.md (`pnpm env:reference` regenerates it).
# The face's slash commands (/model, /auth, /discord-scope, /push, /voice,
# /harness, /layout, ...) write this file for you; hand-editing is optional.

# --- Brain model ------------------------------------------------------------
# codex (default) | claude | local | xai | gemini
#CLANKY_MODEL_PROVIDER=codex
#CLANKY_CODEX_MODEL=gpt-5.5
#CLANKY_CODEX_EFFORT=medium
#CLANKY_CLAUDE_MODEL=claude-opus-4-8
#CLANKY_LOCAL_MODEL=qwen3-coder-next
#CLANKY_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
#CLANKY_XAI_MODEL=grok-4
#CLANKY_GEMINI_MODEL=gemini-3-pro

# --- API keys (only for the routes you use) ---------------------------------
#CLANKY_OPENAI_API_KEY=
#CLANKY_XAI_API_KEY=
#CLANKY_GEMINI_API_KEY=
#CLANKY_ELEVENLABS_API_KEY=

# --- Eve server address (defaults are fine on one machine) -------------------
#CLANKY_EVE_PORT=2000
#CLANKY_EVE_BIND_HOST=127.0.0.1
#CLANKY_EVE_BASE_URL=http://127.0.0.1:2000

# --- iOS relay ----------------------------------------------------------------
# Required for the iOS app; the relay is fail-closed without it.
#CLANKY_RELAY_TOKEN=

# --- Discord presence -----------------------------------------------------------
#CLANKY_DISCORD_PRESENCE=1
#CLANKY_DISCORD_TOKEN=
#CLANKY_DISCORD_CREDENTIAL_KIND=bot-token
#CLANKY_DISCORD_ALLOWED_GUILD_IDS=
#CLANKY_DISCORD_ALLOWED_CHANNEL_IDS=
#CLANKY_DISCORD_ALLOW_DMS=1
#CLANKY_DISCORD_VOICE=0

# --- Voice runtime ----------------------------------------------------------------
#CLANKY_VOICE_REALTIME_PROVIDER=openai
#CLANKY_VOICE_REALTIME_MODEL=gpt-realtime
#CLANKY_VOICE_TTS_PROVIDER=realtime
#CLANKY_ELEVENLABS_VOICE_ID=

# --- Push notifications (iOS APNs) ---------------------------------------------------
#CLANKY_APNS_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8
#CLANKY_APNS_KEY_ID=
#CLANKY_APNS_TEAM_ID=
#CLANKY_APNS_BUNDLE_ID=io.clanky.ios
#CLANKY_APNS_ENV=sandbox

# --- Media -------------------------------------------------------------------------------
#CLANKY_IMAGE_PROVIDER=openai
#CLANKY_VISION_ENABLED=0
#CLANKY_VISION_MODEL=

# --- Workers -----------------------------------------------------------------------------
#CLANKY_CODING_HARNESSES=clanky,claude,codex
#CLANKY_WORKER_TRANSCRIPTS=1
