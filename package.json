		"smoke:agent-tools": "tsx packages/clanky-core/test/agent-tools-smoke.ts",
		"smoke:cli": "tsx packages/clanky-cli/test/cli-smoke.ts",
		"smoke:cli-gateway": "tsx packages/clanky-cli/test/cli-gateway-smoke.ts",
