{
  "name": "clanky",
  "version": "0.1.0",
  "description": "Discord AI user bot persona for community interaction with dashboard and memory",
  "type": "module",
  "main": "src/app.ts",
  "scripts": {
    "postinstall": "bun scripts/install-submodule-deps.mjs",
    "prestart": "bun run build:ui && bun run build:voice",
    "start": "bun src/app.ts",
    "predev": "bun run build:ui",
    "dev": "bun --watch src/app.ts",
    "dev:ui": "bunx vite",
    "build:ui": "bunx vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "bunx tsc -b --noEmit",
    "cleanup": "bun run lint:fix && bun run typecheck",
    "test:default:files": "bun scripts/list-default-test-files.ts",
    "test": "bun test $(bun run --silent test:default:files)",
    "test:e2e": "bun test ./tests/e2e",
    "test:e2e:voice": "RUN_E2E_VOICE_PHYSICAL=1 bun test ./tests/e2e/voicePhysicalHarness.test.ts",
    "test:e2e:text": "RUN_E2E_TEXT=1 bun test ./tests/e2e/textHarness.test.ts",
    "test:coverage": "bun test --coverage $(bun run --silent test:default:files)",
    "test:coverage:check": "bun test --coverage $(bun run --silent test:default:files)",
    "docs:check": "bun scripts/check-doc-links.mjs",
    "replay:flooding": "bun scripts/floodingReplayHarness.ts --mode recorded",
    "replay:flooding:live": "bun scripts/floodingReplayHarness.ts --mode live",
    "replay:voice-golden": "bun scripts/voiceGoldenHarness.ts --mode simulated",
    "replay:voice-golden:live": "bun scripts/voiceGoldenHarness.ts --mode live",
    "logs:loki:up": "docker compose -f docker-compose.loki.yml up -d",
    "logs:loki:down": "docker compose -f docker-compose.loki.yml down",
    "check": "bun run lint && bun run typecheck && bun scripts/check-backend.mjs && bunx vite build",
    "diagrams": "bun scripts/gen-diagrams.mjs",
    "build:voice": "bun scripts/build-voice.ts",
    "browser:login": "agent-browser --profile ~/.clanky/browser-profile --args '--disable-blink-features=AutomationControlled' --headed open",
    "kill:port": "lsof -ti :8787 | xargs kill -9 2>/dev/null || echo 'Port 8787 is free'"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.74.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "hono": "^4.12.5",
    "openai": "^4.80.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sqlite-vec": "^0.1.7-alpha.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@discordjs/voice": "^0.19.0",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "bun-types": "^1.3.10",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.3.1"
  }
}
