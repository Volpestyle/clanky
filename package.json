		"smoke:dashboard-watch": "tsx packages/clanky-tui/test/dashboard-watch-smoke.ts",
		"smoke:daemon-lock": "tsx packages/clanky-gateway/test/daemon-lock-smoke.ts",
		"smoke:doctor": "tsx packages/clanky-cli/test/doctor-smoke.ts",
		"smoke:external-mcp": "tsx packages/clanky-gateway/test/external-mcp-smoke.ts",
		"smoke:http": "tsx packages/clanky-gateway/test/http-smoke.ts",
		"smoke:http-token": "tsx packages/clanky-gateway/test/http-token-smoke.ts",
		"smoke:http-swarm": "tsx packages/clanky-gateway/test/http-swarm-smoke.ts",
		"smoke:install": "tsx packages/clanky-cli/test/install-smoke.ts",
