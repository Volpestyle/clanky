		"smoke:live-gates": "tsx packages/clanky-cli/test/live-gates-smoke.ts",
		"smoke:mcp": "tsx packages/clanky-gateway/test/mcp-smoke.ts",
		"smoke:mcp-swarm": "tsx packages/clanky-gateway/test/mcp-swarm-smoke.ts",
		"smoke:package-manager": "tsx packages/clanky-cli/test/package-manager-smoke.ts",
		"smoke:profiles": "tsx packages/clanky-gateway/test/profile-isolation-smoke.ts",
		"smoke:profile-daemons": "tsx packages/clanky-gateway/test/profile-daemons-smoke.ts",
		"smoke:registry": "tsx packages/clanky-core/test/session-registry-smoke.ts",
