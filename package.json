		"smoke:swarm-activity-linear": "tsx packages/clanky-gateway/test/swarm-activity-linear-smoke.ts",
		"smoke:swarm-restart": "tsx packages/clanky-gateway/test/swarm-restart-smoke.ts",
		"smoke:tui": "tsx packages/clanky-tui/test/chat-rpc-smoke.ts",
		"smoke:ws": "tsx packages/clanky-gateway/test/ws-smoke.ts"
