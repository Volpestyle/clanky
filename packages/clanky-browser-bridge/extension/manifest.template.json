{
	"manifest_version": 3,
	"name": "Clanky Browser Bridge",
	"version": "0.6.0",
	"description": "Lets the local Clanky agent open and control tabs in this browser.",
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"permissions": ["tabs", "alarms", "debugger", "scripting"],
	"host_permissions": ["ws://127.0.0.1/*", "wss://127.0.0.1/*", "<all_urls>"],
	"minimum_chrome_version": "104"
}
