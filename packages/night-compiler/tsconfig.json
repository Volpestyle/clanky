{
	"compilerOptions": {
		"target": "ES2024",
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"skipLibCheck": true,
		"types": ["node", "vite/client", "react", "react-dom"]
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
